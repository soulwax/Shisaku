# Copy this file to .env.local for local development.

# --- Data stores ---
DATABASE_URL=
DATABASE_URL_UNPOOLED=
REDIS_URL=

# --- GitHub OAuth app ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Instance owner ---
# Your GitHub login (the part after github.com/). This account becomes the admin
# author. Leave empty and no one has admin access. Case-insensitive.
ADMIN_GITHUB_USERNAME=
