# Copy this file to .env.local for local development.

# --- Data stores ---
DATABASE_URL=<your database url, e.g. postgresql://localhost:5432/shisaku>
DATABASE_URL_UNPOOLED=<your database url, e.g. postgresql://localhost:5432/shisaku>
REDIS_URL=<your redis url, e.g. redis://localhost:6379/0>

# --- GitHub OAuth app ---
GITHUB_CLIENT_ID="register a new OAuth app at https://github.com/settings/applications/new"
GITHUB_CLIENT_SECRET="register a new OAuth app at https://github.com/settings/applications/new"

# --- Instance owner ---
# Your GitHub login (the part after github.com/). This account becomes the admin
# author. Leave empty and no one has admin access. Case-insensitive.
ADMIN_GITHUB_USERNAME="<if you want to be the admin, put your GitHub username here>"
BLOG_API_CLIENT_ID="shisaku-api-client <or generate one with `openssl rand -hex 32`> it doesn't matter, just needs to be unique"
BLOG_API_CLIENT_SECRET="<generate one with `openssl rand -hex 32`>"