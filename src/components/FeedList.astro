---
import type { Post } from '../db/schema';

interface Props {
	posts: Post[];
}

const { posts } = Astro.props;

const formatFeedDate = (date: Date) =>
	date
		.toISOString()
		.slice(0, 10)
		.replaceAll('-', '.');
---

<div class="feed">
	{
		posts.map((post, index) => (
			<a class:list={['entry', { featured: index === 0 }]} href={`/blog/${post.slug}/`}>
				<div class="entry-meta">
					<span>{formatFeedDate(post.pubDate)}</span>
					<span class="sep">&middot;</span>
					<span class="badge">{index === 0 ? 'latest' : 'note'}</span>
					<span class="sep">&middot;</span>
					<span>~{post.readTimeMinutes} min read</span>
				</div>
				<div class="entry-title">
					<span class="caret">&gt;</span> {post.title}
				</div>
				<p class="entry-dek">{post.description}</p>
				<div class="entry-foot">
					<div class="entry-tags">
						{post.tags.map((tag) => <span class="tag">+{tag}</span>)}
						{post.updatedDate && <span class="tag">+updated</span>}
					</div>
					<span class="entry-read">
						read <span class="arr">-&gt;</span>
					</span>
				</div>
			</a>
		))
	}
</div>

{
	posts.length === 0 && (
		<div class="feed-empty">
			<span class="c2">//</span> no entries yet
			<span class="cursor" style="height:13px;" />
		</div>
	)
}
