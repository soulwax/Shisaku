---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { getAdminGitHubUsername, isAuthorizedAdminUser } from '../../lib/auth/github';

const user = Astro.locals.user;
const isAdmin = user ? isAuthorizedAdminUser(user) : false;

if (isAdmin) {
	return Astro.redirect('/admin');
}

const adminUsername = getAdminGitHubUsername();
const adminLabel = adminUsername ? `@${adminUsername}` : 'the configured admin account';
const error = Astro.url.searchParams.get('error');
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Admin login · shisaku" description="Sign in to manage the shisaku devlog." />
	</head>
	<body>
		<Header />
		<main class="wrap auth-page">
			<div class="prompt">$ auth github</div>
			<h1>Admin sign in</h1>
			{
				user ? (
					<p>You are signed in as @{user.username}. Admin access is restricted to {adminLabel}.</p>
				) : (
					<p>GitHub admin access is restricted to {adminLabel}.</p>
				)
			}
			{error && <p class="form-error" role="alert">{error}</p>}
			{!user && <a class="button" href="/admin/oauth/github/start">Continue with GitHub</a>}
		</main>
		<Footer />
	</body>
</html>
