---
import BaseHead from '../../components/BaseHead.astro';
import FeedList from '../../components/FeedList.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { listPublishedPosts } from '../../lib/posts';

const posts = await listPublishedPosts();
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} · archive`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="wrap feed-page">
			<div class="prompt">$ ls -t devlog/archive <span class="cursor"></span></div>
			<p class="feed-intro">
				<span class="c">//</span> archive of all shisaku devlog entries, newest first.
			</p>
			<FeedList posts={posts} />
		</main>
		<Footer />
	</body>
</html>
