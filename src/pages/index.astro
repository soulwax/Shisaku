---
import BaseHead from '../components/BaseHead.astro';
import FeedList from '../components/FeedList.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { listPublishedPosts } from '../lib/posts';

const posts = await listPublishedPosts();
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} · devlog`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="wrap feed-page">
			<div class="prompt">$ ls -t devlog/ <span class="cursor"></span></div>
			<p class="feed-intro">
				<span class="c">//</span> notes from building <strong>EchoWarrior</strong> and the tools around
				it. A dark-first devlog about games, systems, and work that can be opened up, inspected,
				and changed.
			</p>
			<FeedList posts={posts} />
			<div class="feed-empty">
				<span class="c2">//</span> more as the build continues
				<span class="cursor" style="height:13px;"></span>
			</div>
		</main>
		<Footer />
	</body>
</html>
